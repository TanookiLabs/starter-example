generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ═══════════════════════════════════════════════════════════════
// Auth.js tables — required for authentication
// Do not rename these models or their fields; Auth.js expects this exact schema.
// ═══════════════════════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?

  accounts   Account[]
  sessions   Session[]
  pitches    Pitch[]
  votes      Vote[]
  liveRooms  LiveRoom[]

  @@map("users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

// ═══════════════════════════════════════════════════════════════
// Your app tables — add your own models below
// After editing, run: npm run db:push
// ═══════════════════════════════════════════════════════════════

model Pitch {
  id          String   @id @default(cuid())
  title       String
  description String
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  roasts    Roast[]
  votes     Vote[]
  liveRooms LiveRoom[]

  @@map("pitches")
}

model Roast {
  id        String   @id @default(cuid())
  content   String
  pitchId   String
  createdAt DateTime @default(now())

  pitch Pitch @relation(fields: [pitchId], references: [id], onDelete: Cascade)

  @@map("roasts")
}

model Vote {
  id        String   @id @default(cuid())
  value     Int      // 1 for upvote, -1 for downvote
  pitchId   String
  userId    String
  createdAt DateTime @default(now())

  pitch Pitch @relation(fields: [pitchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pitchId, userId])
  @@map("votes")
}

// Live room for Kahoot-style real-time roasting sessions
model LiveRoom {
  id            String   @id @default(cuid())
  roomCode      String   @unique
  hostId        String
  activePitchId String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  host        User   @relation(fields: [hostId], references: [id], onDelete: Cascade)
  activePitch Pitch? @relation(fields: [activePitchId], references: [id])

  @@map("live_rooms")
}

